{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "tH-Wiki Changelog",
    "type": "object",
    "properties": {
        "versions": {
            "type": "object",
            "properties": {
                "UNRELEASED": {
                    "$ref": "#/$defs/unreleasedVersion"
                }
            },
            "patternProperties": {
                "^([0-9]+)\\.([0-9]+)\\.([0-9]+)$": {
                    "$ref": "#/$defs/releasedVersion"
                }
            }
        }
    },
    "required": [
        "versions"
    ],
    "$defs": {
        "unreleasedVersion": {
            "type": "object",
            "properties": {
                "notes": {
                    "type": "string",
                    "minLength": 1,
                    "description": "can contain inline Markdown"
                },
                "changes": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/change"
                    }
                }
            },
            "required": ["changes"],
            "additionalProperties": false
        },
        "releasedVersion": {
            "type": "object",
            "properties": {
                "date": {
                    "type": "string",
                    "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
                },
                "title": {
                    "type": "string",
                    "minLength": 1,
                    "description": "can contain inline Markdown"
                },
                "notes": {
                    "type": "string",
                    "minLength": 1,
                    "description": "can contain inline Markdown"
                },
                "changes": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/change"
                    }
                }
            },
            "required": ["date", "title", "changes"],
            "additionalProperties": false
        },
        "change": {
            "type": "object",
            "properties": {
                "type": {
                    "enum": [
                        "feature",
                        "bugfix",
                        "performance",
                        "security",
                        "docs",
                        "refactoring",
                        "test",
                        "build",
                        "cleanup",
                        "other"
                    ]
                },
                "text": {
                    "type": "string",
                    "minLength": 1,
                    "description": "can contain inline Markdown"
                }
            },
            "required": ["type", "text"]
        }
    }
}
